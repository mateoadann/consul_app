FLASK_ENV=development
SECRET_KEY=change-me-in-production

POSTGRES_DB=consul_app
POSTGRES_TEST_DB=consul_app_test
POSTGRES_USER=consul
POSTGRES_PASSWORD=consul

DATABASE_URL=postgresql+psycopg2://consul:consul@db:5432/consul_app
TEST_DATABASE_URL=postgresql+psycopg2://consul:consul@db:5432/consul_app_test

SESSION_TYPE=redis
SESSION_REDIS_URL=redis://redis:6379/0
SESSION_COOKIE_SECURE=false

UPLOADS_DIR=/app/uploads
GUNICORN_WORKERS=4

APP_HOST=0.0.0.0
APP_PORT=5002
WEB_PORT=8080
NPM_NETWORK=npm_proxy
